# Qwry server
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgres://j4nya0@localhost:5432/qwry
DEFAULT_SEARCH_PROVIDER=hybrid
SEARXNG_ENABLED=true
SEARXNG_BASE_URL=http://127.0.0.1:8080/
SEARXNG_TIMEOUT_SECONDS=5.0
ENGINE_BASE_URL=http://127.0.0.1:8001/
ENGINE_TIMEOUT_SECONDS=5.0
CRAWLER_ENABLED=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Qwry client
VITE_API_BASE_URL=http://127.0.0.1:8000

# SearXNG container
SEARXNG_PORT=8080
SEARXNG_SECRET=change-this-before-production
SEARXNG_VERSION=latest
SEARXNG_WORKERS=2
